local function Initialize()
    -- Key System
    local keyVerified = CreateKeySystem()
    if not keyVerified then
        return
    end
    
    -- Loading Screen
    CreateLoadingScreen()
    
    -- Find Remotes
    Remotes = FindRemotes()
    if not Remotes then
        warn("[Kira Hub] Failed to find remotes, server hopping...")
        ServerHop()
        return
    end
    
    -- Find Unclaimed Booths
    if not FindUnclaimed() or #unclaimed == 0 then
        warn("[Kira Hub] No unclaimed booths, server hopping...")
        ServerHop()
        return
    end
    
    -- Claim Booth
    local claimed = false
    for i = 1, math.min(#unclaimed, 3) do
        if ClaimBooth() then
            claimed = true
            break
        end
        table.remove(unclaimed, 1)
    end
    
    if not claimed then
        warn("[Kira Hub] Failed to claim booth, server hopping...")
        ServerHop()
        return
    end
    
    -- Create Main GUI
    local guiRefs = CreateMainGUI()
    
    -- Walk to Booth
    WalkToBooth()
    
    -- Initialize Values
    RaisedC = tonumber(LocalPlayer.leaderstats.Raised.Value) or 0
    
    -- Update GUI
    UpdateGUI(guiRefs)
    
    -- Start Begging
    if getgenv().settings.autoBeg then
        spamThread = task.spawn(BeggingLoop)
    end
    
    -- Start Server Hop Timer
    SetHopTimer()
    
    -- Update Booth Text
    UpdateBoothText()
    
    -- Anti-AFK
    task.spawn(function()
        local VirtualUser = game:GetService("VirtualUser")
        LocalPlayer.Idled:Connect(function()
            VirtualUser:CaptureController()
            VirtualUser:ClickButton2(Vector2.new())
        end)
    end)
    
    -- Queue on Teleport
    if queueonteleport then
        queueonteleport([[loadstring(game:HttpGet("YOUR_SCRIPT_URL"))()]])
    end
    
    -- Donation Handler
    LocalPlayer.leaderstats.Raised.Changed:Connect(function()
        task.wait(0.5)
        
        local newRaised = tonumber(LocalPlayer.leaderstats.Raised.Value) or 0
        local donation = newRaised - RaisedC
        
        if donation <= 0 then return end
        
        local donor = GetNearestPlayer()
        local donorName = donor and donor.Name or "Unknown"
        
        sessionEarned = sessionEarned + donation
        lastDonor = {name = donorName, amount = donation, time = tick()}
        
        -- Update GUI
        UpdateGUI(guiRefs)
        
        -- Reset hop timer
        SetHopTimer()
        
        -- Webhook
        if getgenv().settings.webhookToggle then
            SendWebhook(donation, donorName)
        end
        
        -- Thank you
        if getgenv().settings.autoThanks then
            task.spawn(function()
                task.wait(getgenv().settings.thanksDelay + Utility.RandomDelay(-1, 2))
                local msg = getgenv().settings.thanksMessage[math.random(#getgenv().settings.thanksMessage)]
                Chat(msg)
            end)
        end
        
        -- Donation reactions
        if getgenv().settings.donationJump then
            local jumps = donation * getgenv().settings.jumpsPerRobux
            task.spawn(function()
                for i = 1, math.min(jumps, 20) do
                    LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.wait(0.6)
                end
            end)
        end
        
        if getgenv().settings.spinSet then
            local spin = LocalPlayer.Character.HumanoidRootPart:FindFirstChild("Spin")
            if spin then
                local newSpeed = spin.AngularVelocity.Y + (donation * getgenv().settings.spinSpeedMultiplier)
                spin.AngularVelocity = Vector3.new(0, newSpeed, 0)
            end
        end
        
        -- Server hop after donation
        if getgenv().settings.serverHopAfterDonation then
            task.wait(3)
            ServerHop()
        end
        
        -- Update booth text
        task.spawn(function()
            task.wait(getgenv().settings.textUpdateDelay)
            UpdateBoothText()
        end)
        
        RaisedC = newRaised
    end)
    
    -- Quick Action Buttons
    guiRefs.ServerHopBtn.MouseButton1Click:Connect(ServerHop)
    
    guiRefs.WebhookBtn.MouseButton1Click:Connect(function()
        if getgenv().settings.webhookBox ~= "" then
            SendWebhook(0, "Test")
        end
    end)
    
    guiRefs.TestBtn.MouseButton1Click:Connect(function()
        LocalPlayer.leaderstats.Raised.Value = LocalPlayer.leaderstats.Raised.Value + 10
    end)
    
    -- Mark as loaded
    getgenv().KiraHubLoaded = true
    
    print("[Kira Hub] Loaded successfully!")
    print("[Kira Hub] Booth claimed: " .. unclaimed[1])
    print("[Kira Hub] Press LEFT SHIFT to toggle GUI")
end

