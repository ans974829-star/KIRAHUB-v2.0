-- Get nearest player
local function GetNearestPlayer()
    local myChar = LocalPlayer.Character
    if not myChar then return nil end
    
    local myRoot = myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    local nearest, minDist = nil, math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (root.Position - myRoot.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    nearest = player
                end
            end
        end
    end
    
    return nearest
end

-- Webhook
local webhookCooldown = 0

local function SendWebhook(raised, donor)
    if tick() - webhookCooldown < 2 then return end
    webhookCooldown = tick()
    
    local url = getgenv().settings.webhookBox:match("%S+")
    if not url or url == "" or not httprequest then return end
    
    local embed = {
        title = LocalPlayer.Name .. " received a donation!",
        description = string.format("**Amount:** %d R$\n**Donor:** %s\n**Total:** %d R$\n**After Tax:** %d R$",
            raised, donor, tonumber(LocalPlayer.leaderstats.Raised.Value), math.floor(raised * 0.6)),
        color = 0x2ECC71,
        thumbnail = {url = string.format("https://www.roblox.com/headshot-thumbnail/image?userId=%d&width=256&height=256&format=png", LocalPlayer.UserId)},
        timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
    }
    
    local content = (getgenv().settings.pingEveryone and raised >= getgenv().settings.pingAboveDono) and "@everyone" or nil
    
    pcall(function()
        httprequest({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({content = content, embeds = {embed}})
        })
    end)
end

