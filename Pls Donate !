local Utility = {}

function Utility.Create(className, properties)
    local instance = Instance.new(className)
    for property, value in pairs(properties or {}) do
        if property ~= "Parent" then
            instance[property] = value
        end
    end
    if properties and properties.Parent then
        instance.Parent = properties.Parent
    end
    return instance
end

function Utility.Tween(instance, properties, tweenInfo)
    local tween = TweenService:Create(instance, tweenInfo or Animations.Normal, properties)
    tween:Play()
    return tween
end

function Utility.AddCorner(instance, radius)
    return Utility.Create("UICorner", {
        CornerRadius = radius or Theme.CornerRadius,
        Parent = instance
    })
end

function Utility.AddStroke(instance, color, thickness, transparency)
    return Utility.Create("UIStroke", {
        Color = color or Theme.Primary,
        Thickness = thickness or 1,
        Transparency = transparency or 0.5,
        Parent = instance
    })
end

function Utility.AddPadding(instance, padding)
    return Utility.Create("UIPadding", {
        PaddingTop = padding or Theme.Padding,
        PaddingBottom = padding or Theme.Padding,
        PaddingLeft = padding or Theme.Padding,
        PaddingRight = padding or Theme.Padding,
        Parent = instance
    })
end

function Utility.AddGradient(instance, colors, rotation)
    local gradient = Utility.Create("UIGradient", {
        Rotation = rotation or 90,
        Parent = instance
    })
    
    if type(colors) == "table" then
        local keypoints = {}
        for i, color in ipairs(colors) do
            table.insert(keypoints, ColorSequenceKeypoint.new((i-1)/(#colors-1), color))
        end
        gradient.Color = ColorSequence.new(keypoints)
    end
    
    return gradient
end

function Utility.DestroyExisting(name)
    local existing = CoreGui:FindFirstChild(name)
    if existing then
        existing:Destroy()
    end
end

function Utility.FormatNumber(n)
    if n >= 1000000 then
        return string.format("%.1fM", n / 1000000)
    elseif n >= 1000 then
        return string.format("%.1fK", n / 1000)
    else
        return tostring(n)
    end
end

function Utility.RandomDelay(min, max)
    return math.random(min * 10, max * 10) / 10
end

