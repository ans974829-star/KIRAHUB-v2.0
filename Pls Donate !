            for i = 1, 6 do
                InputContainer.Position = originalPos + UDim2.new(0, (i % 2 == 0) and 8 or -8, 0, 0)
                task.wait(0.04)
            end
            InputContainer.Position = originalPos
            return false
        end
    end
    
