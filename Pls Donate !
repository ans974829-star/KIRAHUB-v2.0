-- Claim booth
local function ClaimBooth()
    if not Remotes then return false end
    
    local success = pcall(function()
        Remotes.Event("ClaimBooth"):InvokeServer(unclaimed[1])
    end)
    
    if not success then return false end
    
    task.wait(1)
    
    local boothUI = getgenv()._boothlocation.BoothUI:FindFirstChild("BoothUI" .. unclaimed[1])
    if boothUI and boothUI.Details and boothUI.Details.Owner then
        return boothUI.Details.Owner.Text:find(LocalPlayer.DisplayName) ~= nil
    end
    
    return false
end

-- Walk to booth
local function WalkToBooth()
    local char = LocalPlayer.Character
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not root then return end
    
    for _, interact in ipairs(workspace.BoothInteractions:GetChildren()) do
        local slotNum = interact:GetAttribute("BoothSlot") or tonumber(interact.Name:match("%d+"))
        if slotNum == unclaimed[1] then
            local offset = CFrame.new(0, 0, getgenv().settings.boothPosition)
            local targetCF = interact.CFrame * offset
            
            humanoid.WalkSpeed = 24
            humanoid:MoveTo(targetCF.Position)
            humanoid.MoveToFinished:Wait()
            
            root.CFrame = CFrame.new(targetCF.Position)
            humanoid.WalkSpeed = 16
            
            Chat("/e dance" .. getgenv().settings.danceChoice)
            break
        end
    end
end

