-- Find Remotes
local function FindRemotes()
    for _, v in ipairs(ReplicatedStorage:GetChildren()) do
        if v:IsA("ModuleScript") and v.Name:lower():find("remote") then
            local success, result = pcall(function()
                return require(v)
            end)
            if success and type(result) == "table" and result.Event then
                return result
            end
        end
    end
    return nil
end

-- Find unclaimed booths
local function FindUnclaimed()
    unclaimed = {}
    
    local boothLocation
    local mapUI = workspace:FindFirstChild("MapUI")
    
    if mapUI then
        boothLocation = mapUI
    else
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            local container = playerGui:FindFirstChild("MapUIContainer")
            if container then
                boothLocation = container:FindFirstChild("MapUI")
            end
        end
    end
    
    if not boothLocation then
        return false
    end
    
    getgenv()._boothlocation = boothLocation
    
    local boothUI = boothLocation:FindFirstChild("BoothUI")
    local interactions = workspace:FindFirstChild("BoothInteractions")
    
    if not boothUI or not interactions then
        return false
    end
    
    for _, uiFrame in ipairs(boothUI:GetChildren()) do
        local success, isUnclaimed = pcall(function()
            return uiFrame:FindFirstChild("Details") 
                and uiFrame.Details:FindFirstChild("Owner")
                and uiFrame.Details.Owner.Text == "unclaimed"
        end)
        
        if success and isUnclaimed then
            local boothNum = tonumber(uiFrame.Name:match("%d+"))
            if boothNum then
                for _, interact in ipairs(interactions:GetChildren()) do
                    local slotNum = interact:GetAttribute("BoothSlot") or tonumber(interact.Name:match("%d+"))
                    if slotNum == boothNum then
                        local pos2D = Vector3.new(interact.Position.X, 0, interact.Position.Z)
                        local mainPos2D = Vector3.new(mainCheckPosition.X, 0, mainCheckPosition.Z)
                        if (pos2D - mainPos2D).Magnitude < 92 then
                            table.insert(unclaimed, boothNum)
                            break
                        end
                    end
                end
            end
        end
    end
    
    return #unclaimed > 0
end

-- Server hop
local function ServerHop()
    local PlaceId = getgenv().settings.vcServer and 8943844393 or 8737602449
    
    if getgenv().settings.AlternativeHop then
        PlaceId = math.random() < 0.5 and 8943844393 or 8737602449
    end
    
    if not httprequest then
        TeleportService:Teleport(PlaceId, LocalPlayer)
        return
    end
    
    local success, response = pcall(function()
        return httprequest({
            Url = string.format("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true", PlaceId)
        })
    end)
    
    if not success or not response then
        TeleportService:Teleport(PlaceId, LocalPlayer)
        return
    end
    
    local data = HttpService:JSONDecode(response.Body)
    if not data or not data.data then
        TeleportService:Teleport(PlaceId, LocalPlayer)
        return
    end
    
    local servers = {}
    for _, server in pairs(data.data) do
        if server.playing < 25 and server.id ~= game.JobId and server.playing > 12 then
            table.insert(servers, server)
        end
    end
    
    if #servers > 0 then
        local selected = servers[math.random(#servers)]
        TeleportService:TeleportToPlaceInstance(PlaceId, selected.id, LocalPlayer)
    else
        TeleportService:Teleport(PlaceId, LocalPlayer)
    end
end

